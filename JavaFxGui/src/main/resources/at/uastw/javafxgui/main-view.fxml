<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="at.uastw.javafxgui.controller.EnergyGuiController">

   <children>

      <!-- TITLE -->
      <Label layoutX="180" layoutY="20"
             text="Energy Community Monitor"
             style="-fx-font-size: 20px; -fx-font-weight: bold;" />

      <!-- CURRENT ENERGY SECTION -->
      <Label layoutX="50" layoutY="80" text="Current Energy" />

      <Label layoutX="50" layoutY="110"
             text="Community / Grid:" />

      <Label fx:id="lb_status"
             layoutX="200" layoutY="110"
             text="No data loaded yet" />

      <Button layoutX="50" layoutY="150"
              text="Refresh"
              onAction="#onLoadCurrentEnergyClick"/>

      <Separator layoutX="50" layoutY="190" prefWidth="500"/>

      <!-- HISTORICAL SECTION -->
      <Label layoutX="50" layoutY="210"
             text="Historical Data"
             style="-fx-font-size: 14px; -fx-font-weight: bold;" />

      <Label layoutX="50" layoutY="250" text="Start:" />
      <ComboBox fx:id="cb_start"
                layoutX="120" layoutY="245"
                prefWidth="200"/>

      <Label layoutX="50" layoutY="290" text="End:" />
      <ComboBox fx:id="cb_end"
                layoutX="120" layoutY="285"
                prefWidth="200"/>

      <Button layoutX="350" layoutY="265"
              text="Show Data"
              onAction="#onLoadHistoricalClick"/>

      <!-- RESULTS -->
      <Label fx:id="lb_produced"
             layoutX="50" layoutY="340"
             text="Produced: -" />

      <Label fx:id="lb_used"
             layoutX="50" layoutY="370"
             text="Used: -" />

      <Label fx:id="lb_grid_used"
             layoutX="50" layoutY="400"
             text="Grid: -" />

   </children>
</AnchorPane>